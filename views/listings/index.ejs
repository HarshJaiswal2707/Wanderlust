<% layout("/layouts/boilerplate")%>
    <h3>AllListings</h3>
    <!-- <form method="GET" action="/listings/new">
        <button>Create New Listing</button>
    </form> -->
    <style>
        #filters {
            display: flex;
            flex-wrap: wrap;
            align-items: center;
        }

        /* normal screen */
        .filter {
            text-align: center;
            margin: 1rem;
            opacity: 0.7;
        }

        .filter:hover {
            opacity: 1;
            cursor: pointer;
        }

        .filter p {
            font-size: 0.8rem;
        }

        /* 🔥 MOBILE FIX */
        @media (max-width: 576px) {
            #filters {
                justify-content: center;
            }

            .filter {
                width: 30%;
                margin: 0.5rem;
            }

            .filter p {
                font-size: 0.7rem;
            }
        }

        /* tax toggle */
        .tax-toogle {
            margin-left: auto;
            margin-top: 1rem;
        }

        @media (max-width: 576px) {
            .tax-toogle {
                width: 100%;
                text-align: center;
            }
        }

        /* image */
        .card-img-top {
            height: 20rem;
            object-fit: cover;
        }

        @media (max-width: 576px) {
            .card-img-top {
                height: 15rem;
            }
        }

        .tax-info {
            display: none;
        }

        .tax-toogle {
            border: 1px solid black;
            border-radius: 1rem;
            height: 3.25rem;
            padding: 1rem;
            margin-left: 2rem;
            display: flex;
            align-items: center;
        }
    </style>
    <button class="btn btn-dark d-md-none mb-2" data-bs-toggle="collapse" data-bs-target="#filters">
        Show Filters
    </button>

    <div id="filters" class="collapse d-md-block d-lg-flex">
        <div class="filter">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-bed"></i></div>
            <p>Rooms</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </div>
        <div class="filter">
            <div><i class="fa-brands fa-fort-awesome"></i></i></div>
            <p>Castles</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i></i></div>
            <p>Amazing Pools</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-campground"></i></div>
            <p>Campaign</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-tractor"></i></div>
            <p>Farms</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-igloo"></i></div>
            <p>Domes</p>
        </div>
        <div class="filter">
            <div><i class="fa-solid fa-ship"></i></div>
            <p>Boats</p>
        </div>
        <div class="tax-toogle">
            <div class="form-check-reverse form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
                <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
            </div>
        </div>
    </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-3">
     <% if(allListings.length===0){ %>
                <h4>No results found</h4>
                <% } %>
        <% for (let listing of allListings) { %>
           
                    <a href="/listings/<%= listing._id%>" class="listing-link">
                        <div class="col">

                            <div class="card h-100 listing-card">

                                <img src="<%= listing.image.url %>" class="card-img-top">
                                <div class="card-img-overlay"></div>

                                <div class="card-body">
                                    <p>
                                        <b>
                                            <%= listing.title %>
                                        </b><br>

                                        &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>
                                            /night
                                            <i class="tax-info"> &nbsp; &nbsp;+18% GST</i>
                                    </p>
                                </div>

                            </div>
                        </div>
                    </a>
                    <% } %>
    </div>
    <script>
        let taxSwitch = document.getElementById("switchCheckDefault");
        taxSwitch.addEventListener("change", () => {
            let taxInfo = document.getElementsByClassName("tax-info");
            for (info of taxInfo) {
                if (info.style.display != "inline") {
                    info.style.display = "inline";
                }
                else {
                    info.style.display = "none";
                }

            }
        });

    </script>